{
  "name": "selaras-offline-ext",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bedframe dev",
    "build": "bedframe build",
    "lint": "oxlint --fix .",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "publish": "bedframe publish -b",
    "zip": "bedframe zip",
    "version": "bedframe version",
    "release": "gh release create $npm_package_name@$npm_package_version ./dist/*.zip --generate-notes",
    "fix": "bun run format && bun run lint",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:auth-capture": "bun run scripts/capture-auth.ts",
    "commit": "lint-staged && cz",
    "convert:safari": "xcrun safari-web-extension-converter dist/safari --project-location . --app-name $npm_package_name-safari"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/figtree": "^5.2.10",
    "@hugeicons/core-free-icons": "^4.1.0",
    "@hugeicons/react": "^1.1.6",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "latest",
    "idb": "^8.0.3",
    "react": "latest",
    "react-dom": "latest",
    "react-icons": "latest",
    "shadcn": "^4.1.1",
    "tailwind-merge": "latest",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "latest",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@bedframe/cli": "^0.1.2",
    "@bedframe/core": "^0.1.0",
    "@changesets/cli": "latest",
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "latest",
    "@tailwindcss/vite": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/chrome": "latest",
    "@types/jest": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-istanbul": "latest",
    "commitizen": "latest",
    "concurrently": "latest",
    "cz-conventional-changelog": "latest",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "latest",
    "happy-dom": "latest",
    "lefthook": "latest",
    "lint-staged": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "playwright-extra": "^4.3.6",
    "postcss": "latest",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tailwindcss": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.57.1",
    "vite": "latest",
    "vitest": "latest"
  },
  "description": "Make it offline compatible",
  "license": "MIT",
  "author": {
    "name": "givnnx",
    "email": "giovanniagung@gmail.com",
    "url": "https://giovanniagung.my.id"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,html,json}": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx}": "oxlint --fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
